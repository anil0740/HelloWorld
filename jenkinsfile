pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t helloworld .'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker rm -f helloworld || true

                docker run -d \
                --name helloworld \
                -p 8080:8080 \
                helloworld
                '''
            }
        }
    }
}